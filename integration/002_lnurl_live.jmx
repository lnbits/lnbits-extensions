    &quot;lnurl&quot;: &quot;LNURL1DP68GURN8GHJ7ER9D4HJUMRWVF5HGUEWVDHK6TMVDE6HYMRS9AJHGDT52DNQ97CEPF&quot;,&#xd;
    &quot;unit&quot;: &quot;sat&quot;,&#xd;
    &quot;amount&quot;: 10000,&#xd;
